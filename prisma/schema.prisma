generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String?
  displayName  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  token        String?
  projects     Project[]
  sessions     Session[]
  facts        UserFact[]

  @@map("users")
  calendars Calendar[]
}

model Calendar {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  timezone    String   @default("UTC")
  recurrence  String?  // daily, weekly, monthly, yearly
  reminder    String?  // minutes before: 5, 15, 30, 60, etc.
  status      String   @default("scheduled") // scheduled, completed, cancelled
  location    String?
  color       String?  // hex color for UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
  @@index([status])
  @@map("calendars")
}

model UserFact {
  id        String   @id @default(uuid())
  userId    String
  factKey   String
  factValue String
  confidence Float   @default(1.0)
  source    String   @default("onboarding")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, factKey])
  @@index([userId])
  @@index([factKey])
  @@map("user_facts")
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  userAgent  String?
  ipAddress  String?
  deviceName String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Project {
  id         String           @id @default(uuid())
  name       String
  userId     String?
  createdAt  DateTime         @default(now())
  email      String?
  chats      Chat[]
  folders    Folder[]
  memories   MemoryDocument[]
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaces Workspace[]

  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@map("projects")
}

model Folder {
  id        String   @id @default(uuid())
  projectId String
  name      String
  createdAt DateTime @default(now())
  chats     Chat[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("folders")
}

model Workspace {
  id         String           @id @default(uuid())
  projectId  String
  type       String
  identifier String
  createdAt  DateTime         @default(now())
  chats      Chat[]
  memories   MemoryDocument[]
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("workspaces")
}

model Chat {
  id           String           @id @default(uuid())
  projectId    String
  workspaceId  String?
  folderId     String?
  title        String
  clientSource String           @default("webgui")
  isFavorite   Boolean          @default(false)
  isMain       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  folder       Folder?          @relation(fields: [folderId], references: [id])
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events       Event[]
  memories     MemoryDocument[]
  messages     Message[]

  @@index([projectId])
  @@index([workspaceId])
  @@index([folderId])
  @@index([updatedAt])
  @@index([clientSource])
  @@index([isFavorite])
  @@index([isMain])
  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
  @@map("messages")
}

model Event {
  id        String   @id @default(uuid())
  chatId    String
  type      String
  payload   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([type])
  @@index([createdAt])
  @@map("events")
}

model MemoryDocument {
  id          String        @id @default(uuid())
  scope       String
  projectId   String?
  workspaceId String?
  chatId      String?
  content     String
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())
  chunks      MemoryChunk[]
  chat        Chat?         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([scope, projectId, workspaceId])
  @@unique([scope, chatId])
  @@index([scope])
  @@index([projectId])
  @@index([workspaceId])
  @@index([chatId])
  @@map("memory_documents")
}

model MemoryChunk {
  id              String         @id @default(uuid())
  memoryId        String
  text            String
  embeddingVector String?
  createdAt       DateTime       @default(now())
  memory          MemoryDocument @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("memory_chunks")
}

model Task {
  id              String           @id @default(uuid())
  title           String
  description     String?
  status          String           @default("PENDING")
  priority        Int              @default(0)
  due_date        DateTime?
  estimated_hours Int?
  actual_hours    Int?
  parent_id       String?
  chat_id         String?
  metadata        String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  completed_at    DateTime?
  dependents      TaskDependency[] @relation("TaskDependents")
  dependencies    TaskDependency[] @relation("TaskDependencies")
  events          TaskEvent[]
  parent          Task?            @relation("TaskSubtasks", fields: [parent_id], references: [id], onDelete: Cascade)
  subtasks        Task[]           @relation("TaskSubtasks")

  @@index([chat_id])
  @@index([parent_id])
  @@index([status])
  @@index([priority])
  @@index([created_at])
  @@index([updated_at])
  @@index([due_date])
  @@map("tasks")
}

model TaskDependency {
  id            String   @id @default(uuid())
  task_id       String
  dependency_id String
  created_at    DateTime @default(now())
  dependency    Task     @relation("TaskDependents", fields: [dependency_id], references: [id], onDelete: Cascade)
  task          Task     @relation("TaskDependencies", fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([task_id, dependency_id])
  @@index([task_id])
  @@index([dependency_id])
  @@map("task_dependencies")
}

model TaskEvent {
  id        String   @id @default(uuid())
  taskId    String
  type      String
  data      String?
  timestamp DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type])
  @@index([timestamp])
  @@map("task_events")
}
